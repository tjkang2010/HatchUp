# ============================================================
# ⚙️ HatchUp 환경변수 설정
# ============================================================
# 이 파일을 .env 로 복사 후 값을 채우세요.
# Railway: Variables 탭에서 직접 입력
# ============================================================

# 서버
NODE_ENV=production
PORT=3000

# ⚠️ 반드시 변경! (64자 이상 랜덤 문자열)
# 생성: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=여기에_매우_길고_랜덤한_문자열_절대_이대로_사용금지
JWT_EXPIRES=7d

# 도메인 (배포 후 실제 주소로 변경)
FRONTEND_URL=https://내주소.up.railway.app

# ============================================================
# 💾 데이터베이스
# SQLite: 아무것도 설정 안 하면 자동으로 SQLite 사용
# PostgreSQL: 아래 주석 해제 후 실제 URL 입력
# ============================================================
# DATABASE_URL=postgresql://user:password@host:5432/hatchup

# ============================================================
# 💳 토스페이먼츠
# https://developers.tosspayments.com 에서 발급
# ============================================================
TOSS_CLIENT_KEY=test_ck_여기에_클라이언트키
TOSS_SECRET_KEY=test_sk_여기에_시크릿키
TOSS_WEBHOOK_SECRET=여기에_웹훅_시크릿

# ============================================================
# 🔔 Web Push (VAPID 키)
# 생성: npm run gen-vapid
# ============================================================
VAPID_PUBLIC_KEY=여기에_VAPID_공개키
VAPID_PRIVATE_KEY=여기에_VAPID_비밀키
VAPID_EMAIL=mailto:admin@hatchup.app

# 푸시 알림 체크 간격 (기본 10분)
PUSH_INTERVAL_MS=600000
